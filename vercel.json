{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "functions": {
    "api/chat/query.js": {
      "includeFiles": "public/**"
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/(he|en)(.*)", "destination": "/index.html" }
  ]
}

